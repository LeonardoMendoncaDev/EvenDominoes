{
  "name": "domino",
  "private": true,
  "version": "0.10.1",
  "description": "Classic domino game for Even Reality G2 smart glasses",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "simulate": "evenhub-simulator http://localhost:5173",
    "pack": "npm run build && evenhub pack app.json dist -o domino.ehpk",
    "pack:check": "evenhub pack app.json dist --check"
  },
  "dependencies": {
    "@evenrealities/even_hub_sdk": "^0.0.9"
  },
  "devDependencies": {
    "@evenrealities/evenhub-cli": "^0.1.10",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
